-- Write a query to display all workers.
SELECT *
FROM worker;

-- Fetch first_name and last_name of workers from the IT department.
SELECT first_name , last_name 
FROM worker
WHERE department = 'IT';

-- Find distinct departments from the worker table.
SELECT DISTINCT(department)
FROM worker;

-- Display workers whose salary is greater than 50,000.
SELECT *
FROM worker
WHERE salary > 50000;

-- Find workers who joined after 2021.
SELECT *
FROM worker
WHERE YEAR(joining_date) > 2021;

-- Show workers whose first name starts with 'A'.
SELECT *
FROM worker
WHERE first_name LIKE 'a%';

-- Fetch workers whose last name ends with a vowel.
SELECT *
FROM worker
WHERE last_name REGEXP '[AEIOUaeiou]$';

-- Count the total number of workers.
SELECT COUNT(worker_id) AS No_of_workers
FROM worker;

-- Find the highest salary in the company.
SELECT MAX(salary)
FROM worker;












