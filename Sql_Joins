-- Inner Join
-- is we want the first_name and project name then we can use inner join and do that

SELECT w.firstname , p.projectname ,w.workerid
FROM worker AS w INNER JOIN Project1 AS p
ON w.workerid = p.workerid;


-- Left Join
-- gives Common records[Inner join] + all the remaining records from left table

SELECT w.firstname , p.projectname
FROM Project1 as p LEFT JOIN worker AS w 
ON w.workerid = p.workerid
WHERE p.projectname is NOT NULL;

