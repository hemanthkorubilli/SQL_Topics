-- question. cummulative sum(sum of current and above values)
CREATE TABLE transactions (
    id INT PRIMARY KEY,
    amount INT
);
INSERT INTO transactions VALUES
(1, 100),
(2, 250),
(3, 75),
(4, 0),
(5, 500);

SELECT b.id , SUM(a.amount) as sum
FROM transactions a JOIN transactions b
ON a.id <= b.id
GROUP BY b.id;

