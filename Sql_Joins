-- Self joins
-- in self join we consider same table 2 times and we perform joins on the interlinked columns


CREATE TABLE employees_self (
    emp_id INT PRIMARY KEY,
    emp_name VARCHAR(50),
    department VARCHAR(50),
    manager_id INT
);

