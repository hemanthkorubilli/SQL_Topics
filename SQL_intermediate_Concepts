-- question[ we need to find out the department wise total salary and number of workers WHOSE SALARY IS > 50K and count > 2]
SELECT department , SUM(SALARY) , COUNT(worker_id)
FROM worker
WHERE salary > 50000 and COUNT(worker_id) >= 2   -- in where we cannot give conditions on aggregate columns [thats is where we use having]
GROUP BY department;

-- Having [ to give conditions/ use conditions on aggregate columns we use having]
-- Exmaple
-- question[ we need to find out the department wise total salary and number of workers WHOSE SALARY IS > 50K and count > 2]
SELECT department , SUM(salary) , COUNT(worker_id)
FROM worker
WHERE salary > 50000
GROUP BY department
HAVING COUNT(worker_id ) >= 2;

-- question [ we need those workers whose salary is > 60K and we need have those departments whose count is >= 2]
SELECT department , COUNT(worker_id)
FROM worker
WHERE salary > 60000
GROUP BY department
HAVING COUNT(worker_id) >= 2;


/*
question
number of worker joined in each month
salary > 15000
months where count > 2
order them by count desc
*/
SELECT MONTHNAME(joining_date) AS Month , COUNT(worker_id) AS Number
FROM worker
WHERE salary > 20000
GROUP BY MONTHNAME(joining_date)
HAVING COUNT(worker_id) >= 2
ORDER BY COUNT(worker_id) DESC;	

-- Like 
-- name starts with a?
SELECT *
FROM worker
WHERE first_name LIKE 'a%';

-- name end with a?
SELECT *
FROM worker
WHERE first_name LIKE '%a'; 

-- names that consists of a in any position
SELECT *
FROM worker
WHERE first_name LIKE '%a%'; 

-- name starts with 'm' and end with 'a'?
